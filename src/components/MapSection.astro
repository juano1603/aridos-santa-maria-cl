---
const LAT = -38.9848;
const LNG = -72.7379;
const MAPS_EMBED = `https://maps.google.com/maps?q=${LAT},${LNG}&z=15&output=embed`;
const MAPS_LINK  = `https://maps.google.com/?q=${LAT},${LNG}`;
---

<section id="ubicacion" class="bg-slate-900 py-20 px-4">
  <div class="max-w-6xl mx-auto">

    <!-- Section Header -->
    <div class="text-center mb-12">
      <span class="inline-block text-amber-400 text-sm font-semibold tracking-widest uppercase mb-3">
        ¿Dónde estamos?
      </span>
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4">
        Nuestra <span class="text-amber-400">Ubicación</span>
      </h2>
      <div class="w-16 h-1 bg-amber-500 mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-stretch">

      <!-- Info Card -->
      <div class="lg:col-span-2 flex flex-col gap-5">

        <div class="bg-slate-800/60 border border-slate-700/50 rounded-2xl p-6 flex flex-col gap-5 h-full">

          <!-- Address block -->
          <div class="flex gap-4">
            <div class="shrink-0 w-11 h-11 rounded-xl bg-amber-500/15 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-slate-400 text-xs font-semibold uppercase tracking-wider mb-1">Dirección</p>
              <p class="text-white font-semibold leading-snug">
                Km 9.5 Camino Teodoro Schmidt<br />
                <span class="text-slate-400 font-normal text-sm">Pasado cruce Los Yugos, Freire</span>
              </p>
            </div>
          </div>

          <div class="border-t border-slate-700/50"></div>

          <!-- Region block -->
          <div class="flex gap-4">
            <div class="shrink-0 w-11 h-11 rounded-xl bg-amber-500/15 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
              </svg>
            </div>
            <div>
              <p class="text-slate-400 text-xs font-semibold uppercase tracking-wider mb-1">Cobertura</p>
              <p class="text-white font-semibold">Novena Región de la Araucanía</p>
              <p class="text-slate-400 text-sm">Temuco · Freire · Loncoche · Villarrica · y más</p>
            </div>
          </div>

          <div class="border-t border-slate-700/50"></div>

          <!-- Phone blocks -->
          <div class="flex gap-4">
            <div class="shrink-0 w-11 h-11 rounded-xl bg-amber-500/15 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="text-slate-400 text-xs font-semibold uppercase tracking-wider mb-1">Teléfonos</p>
              <a href="tel:+56985018360" class="block text-white font-semibold hover:text-amber-400 transition-colors">+56 9 8501 8360</a>
              <a href="tel:+56956673196" class="block text-slate-300 hover:text-amber-400 transition-colors">+56 9 5667 3196</a>
            </div>
          </div>

          <!-- CTA button -->
          <a
            href={MAPS_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto flex items-center justify-center gap-2 w-full py-3 rounded-xl
              border-2 border-amber-500/60 text-amber-400 font-semibold text-sm
              hover:bg-amber-500/10 hover:border-amber-400 transition-all duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Abrir en Google Maps
          </a>

        </div>
      </div>

      <!-- Map Iframe -->
      <div class="lg:col-span-3 rounded-2xl overflow-hidden border border-slate-700/50 shadow-card min-h-[320px]">
        <iframe
          title="Ubicación de Áridos Santa María en Freire, Araucanía"
          src={MAPS_EMBED}
          width="100%"
          height="100%"
          style="min-height: 380px; border: 0; filter: invert(90%) hue-rotate(180deg) saturate(0.8);"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>

    </div>
  </div>
</section>
